# Copy this file to .env and fill in your keys
# Never commit .env

# === Primary (used by most tutorials) ===
OPENAI_API_KEY=sk-...

# === Optional providers (swap in code comments) ===
# ANTHROPIC_API_KEY=...
# GOOGLE_API_KEY=...
# GROK_API_KEY=...          # or XAI
# FIREWORKS_API_KEY=...
# OLLAMA_BASE_URL=http://localhost:11434

# === Observability (highly recommended for harness engineering) ===
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT=langchain-showcase

# Optional: Reduce noise in tutorials
LANGCHAIN_VERBOSE=false
